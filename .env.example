# K8s Autopilot — copy to .env and fill in real values
# Never commit .env — it is gitignored

# Slack webhook for operator alerts (optional — leave blank to disable)
SLACK_WEBHOOK_URL=

# API authentication key (shared by all services)
# Generate one with: openssl rand -hex 32
API_KEY=

# Anomaly injection rate — fraction of ticks per pod that trigger an anomaly
# Default 0.003 (~1 per 5 min/pod at 15s ticks). Raise for faster demos, e.g. 0.02
ANOMALY_RATE=0.003